# Copy this file to .env.local and fill in your real values.
# .env.local is in .gitignore so it will NEVER be pushed to GitHub.

# ── Resend (free email API) ────────────────────────────────────────────────────
# Sign up at https://resend.com → API Keys → Create API Key
# Free tier: 100 emails/day, no credit card needed
RESEND_API_KEY=re_YOUR_API_KEY

# The "From" address for outgoing emails.
# On Resend's free tier you can use: onboarding@resend.dev (works immediately)
# For your own domain: verify it in Resend dashboard first.
EMAIL_FROM=onboarding@resend.dev
RESEND_TEST_EMAIL=bilaldelhi03@gmail.com